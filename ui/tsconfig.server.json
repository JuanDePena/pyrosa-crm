{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "rootDir": "server",
    "outDir": "build/server"
  },
  "include": ["server/**/*.ts"],
  "exclude": ["server/**/*.test.ts"]
}
