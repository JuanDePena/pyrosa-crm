  "artifactCoherence": {
    "schemaVersion": 1,
    "application": "pyrosa-democrm",
    "manifest": "build/release-manifest.json",
    "clientRoot": "dist",
    "serverRoot": "build/server",
    "serverEntry": "index.js",
    "requiredHealthFields": ["releaseId", "commit", "artifact"]
  },
  "routes": [
    { "id": "dashboard", "hash": "dashboard", "groupId": "gestion", "groupLabel": "Gestion", "groupOrder": 1, "itemOrder": 1 },
    { "id": "cuentas", "hash": "cuentas", "groupId": "relacion", "groupLabel": "Relacion", "groupOrder": 2, "itemOrder": 1 },
    { "id": "contactos", "hash": "contactos", "groupId": "relacion", "groupLabel": "Relacion", "groupOrder": 2, "itemOrder": 2 },
    { "id": "oportunidades", "hash": "oportunidades", "groupId": "relacion", "groupLabel": "Relacion", "groupOrder": 2, "itemOrder": 3 },
    { "id": "casos", "hash": "casos", "groupId": "operacion", "groupLabel": "Operacion", "groupOrder": 3, "itemOrder": 1 },
    { "id": "actividades", "hash": "actividades", "groupId": "operacion", "groupLabel": "Operacion", "groupOrder": 3, "itemOrder": 2 },
    { "id": "agenda", "hash": "agenda", "groupId": "operacion", "groupLabel": "Operacion", "groupOrder": 3, "itemOrder": 3 },
    { "id": "reportes", "hash": "reportes", "groupId": "analitica", "groupLabel": "Analitica", "groupOrder": 4, "itemOrder": 1 },
    { "id": "configuracion", "hash": "configuracion", "groupId": "gobierno", "groupLabel": "Gobierno", "groupOrder": 5, "itemOrder": 1 }
  ],
  "routeRequiredFields": [
    "id",
    "label",
    "title",
    "description",
    "hash",
    "icon",
    "groupId",
    "groupLabel",
    "groupOrder",
    "itemOrder",
    "keywords"
  ],
  "resourceViews": {
    "routes": ["cuentas", "contactos", "casos", "actividades", "agenda", "oportunidades", "reportes"],
    "modes": ["list", "detail", "new", "edit"],
    "requiredStates": ["loading", "empty", "error", "ready"]
  },
  "dashboard": {
    "component": "DashboardView",
    "endpoint": "/api/crm/v1/dashboard-summary",
    "requiredMarker": "data-dashboard-kind=\"analytic\"",
    "requiredPrimitives": [
      "ExecutiveOverviewHero",
      "ExecutiveOverviewSignals",
      "ExecutiveOverviewScore",
      "ExecutiveOverviewGrid",
      "ExecutiveProgressCard",
      "ExecutiveDomainCard",
      "ExecutiveRiskCard",
      "ExecutiveInsightCard"
    ],
    "forbiddenFragments": ["<DataTable", "<DataTableInline", "<table", "workbenchData", "fixture"]
  },
  "shell": {
    "component": "BusinessOpsShellTemplate",
    "brandTitle": "PYROSA CRM",
    "environment": "demo",
    "overviewBackAction": "hidden",
    "sidebarPersistKey": "pyrosa-democrm",
    "contentScrollPersistKeyPrefix": "democrm-",
    "userLabel": "Cuenta",
    "showTopbarMeta": false
  },
  "fatalError": {
    "boundary": "ApplicationErrorBoundary",
    "component": "InternalErrorLanding",
    "provider": "@pyrosa/ui-templates",
    "requiredParts": ["logo", "title", "subtitle", "message", "technical-details", "retry"],
    "forbiddenFragments": ["error.message", "error.stack", "using fallback", "fallback local"]
  },
  "api": {
    "basePath": "/api/crm/v1",
    "tenantHeader": "X-Pyrosa-Tenant-Id",
    "requiredHeaders": ["Idempotency-Key", "If-Match", "X-CSRF-Token"],
    "forbiddenFragments": ["Promise.allSettled", "fallback-preview", "ui-contract-v0", "scaffold", "Atlas Retail Group", "Nova Servicios"]
  },
  "userDrawer": {
    "component": "UserDrawer",
    "requiredSections": ["Cuenta", "Preferencias UI", "Alcance DemoCRM", "Configuracion efectiva"],
    "forbiddenLocalComponents": ["AccountDrawer", "CrmUserDrawer", "LocalUserDrawer"],
    "forbiddenAuthorityFragments": ["mfaSecret", "passwordHash", "iamClaims", "persistClaims"]
  },
  "css": {
    "classification": {
      "keep": ["crm-dashboard", "crm-detail", "crm-editor", "crm-command", "crm-config", "crm-overview", "crm-notification"],
      "shim": ["crm-workspace", "crm-bootstrap", "crm-filter", "crm-panel", "crm-field", "crm-input", "crm-pagination", "crm-regional"],
      "cleanup": [],
      "blocker": []
    },
    "forbiddenSharedShellOverrides": [
      ".crm-shell .py-sidebar",
      ".crm-shell .py-topbar",
      ".crm-shell .py-app-shell"
    ],
    "forbidHexColors": true,
    "forbidSharedInternals": true
  },
  "visualQa": {
    "outputDirectory": "tmp/qa-visual",
    "manifest": "manifest.json",
    "requiredCases": [
      "desktop-dashboard",
      "desktop-cuentas",
      "desktop-casos",
      "desktop-agenda",
      "desktop-user-drawer",
      "narrow-dashboard",
      "narrow-cuentas",
      "narrow-casos",
      "narrow-agenda",
      "narrow-user-drawer",
      "desktop-fatal-error"
    ],
    "sanitizedEvidence": true
  },
  "rollback": {
    "strategy": "source-revert",
    "steps": [
      "Revertir el commit de UI v2607 sin alterar datos ni contratos CRM.",
      "Restaurar en conjunto el bundle inmutable @pyrosa/ui 0.2.1.",
      "Conservar las rutas hash y el ownership de datos de DemoCRM.",
      "Ejecutar check:pyrosa-ui, typecheck, build y qa:visual antes de reabrir el runtime."
    ],
    "validation": ["check:pyrosa-ui", "typecheck", "build", "qa:visual"]
  }
}
