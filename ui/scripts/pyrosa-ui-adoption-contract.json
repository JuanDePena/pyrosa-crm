{
  "schemaVersion": 2,
  "application": "pyrosa-democrm",
  "profile": "business-ops",
  "theme": "pyrosa-base@1.0.0",
  "status": "ready",
  "sources": {
    "app": "src/CrmApp.tsx",
    "api": "src/crmApi.ts",
    "dashboard": "src/DashboardView.tsx",
    "fatalError": "src/FatalErrorLanding.tsx",
    "resourceConfig": "src/resourceConfig.tsx",
    "resources": "src/ResourceViews.tsx",
    "routes": "src/routeRegistry.tsx",
    "routing": "src/crmRouting.ts",
    "styles": "src/styles.css",
    "visualQa": "scripts/qa-visual-smoke.mjs"
  },
