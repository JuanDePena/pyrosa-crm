APP_NAME=pyrosa-democrm
APP_ENV=development
APP_URL=https://democrm.pyrosa.com.do
APP_SERVICE_NAME=app-pyrosa-democrm.service
APP_CONTAINER_NAME=app-pyrosa-democrm
APP_CANONICAL_DOMAIN=democrm.pyrosa.com.do
APP_DATA_DIR=/srv/containers/apps/pyrosa-democrm/app
APP_UPLOADS_DIR=/srv/containers/apps/pyrosa-democrm/uploads

PYROSA_CRM_UI_HOST=0.0.0.0
PYROSA_CRM_UI_PORT=10166
PYROSA_CRM_UI_ACCESS_LOG=1
PYROSA_CRM_UI_HEALTH_PATH=/__pyrosa_crm_health
PYROSA_CRM_UI_HEALTH_DETAILS=0
PYROSA_CRM_VERSION=v2607
PYROSA_CRM_BRANCH=main

PYROSA_CRM_DB_HOST=10.88.0.1
PYROSA_CRM_DB_PORT=5432
PYROSA_CRM_DB_DATABASE=app_pyrosa_democrm
PYROSA_CRM_DB_USER=app_pyrosa_democrm
PYROSA_CRM_DB_PASSWORD=change-me
PYROSA_CRM_DB_DSN=postgresql://app_pyrosa_democrm:change-me@10.88.0.1:5432/app_pyrosa_democrm

PYROSA_CRM_PLATFORM_BASE_URL=https://platform.pyrosa.com.do
PYROSA_CRM_PLATFORM_INTERNAL_BASE_URL=https://platform.pyrosa.com.do
PYROSA_CRM_IAM_BASE_URL=https://iam.pyrosa.com.do
PYROSA_CRM_IAM_INTERNAL_BASE_URL=https://iam.pyrosa.com.do
PYROSA_CRM_IAM_CLIENT_SLUG=crm
PYROSA_CRM_IAM_CLIENT_SECRET=change-me
PYROSA_CRM_IAM_CALLBACK_URL=https://democrm.pyrosa.com.do/auth/callback
PYROSA_CRM_IAM_SESSION_CHECK_MS=30000
# Resource server read-only para clientes API. Mantener deshabilitado hasta que
# IAM aprovisione el introspector, sus grants y el secret fuera de Git.
PYROSA_CRM_OAUTH_API_ENABLED=false
PYROSA_CRM_OAUTH_API_ISSUER=https://iam.pyrosa.com.do
PYROSA_CRM_OAUTH_API_INTROSPECTION_URL=https://iam.pyrosa.com.do/oauth/introspect
PYROSA_CRM_OAUTH_API_CLIENT_ID=pyrosa-crm-resource-server
PYROSA_CRM_OAUTH_API_CLIENT_SECRET=
PYROSA_CRM_OAUTH_API_AUDIENCE=pyrosa-crm
PYROSA_CRM_OAUTH_API_READ_SCOPE=crm.read
PYROSA_CRM_OAUTH_API_TIMEOUT_MS=4000
PYROSA_CRM_ACCOUNTS_BASE_URL=https://accounts.pyrosa.com.do
PYROSA_CRM_ACCOUNTS_INTERNAL_BASE_URL=https://accounts.pyrosa.com.do

# Decisiones CRM v1 source-only. Aprovisionar tres clientes machine y secretos
# distintos en IAM antes de promover el runtime; vacio mantiene fail-closed.
PYROSA_CRM_DIRECTORY_INTERNAL_BASE_URL=https://directory.pyrosa.com.do
PYROSA_CRM_DIRECTORY_OAUTH_TOKEN_URL=https://iam.pyrosa.com.do/oauth/token
PYROSA_CRM_DIRECTORY_OAUTH_CLIENT_ID=client-pyrosa-democrm
PYROSA_CRM_DIRECTORY_OAUTH_CLIENT_SECRET=
PYROSA_CRM_DIRECTORY_OAUTH_AUDIENCE=pyrosa-directory
PYROSA_CRM_DIRECTORY_OAUTH_SCOPE=directory:crm-access:decide

PYROSA_CRM_STORE_INTERNAL_BASE_URL=https://store.pyrosa.com.do
PYROSA_CRM_STORE_OAUTH_TOKEN_URL=https://iam.pyrosa.com.do/oauth/token
PYROSA_CRM_STORE_OAUTH_CLIENT_ID=client-pyrosa-democrm-store-entitlements
PYROSA_CRM_STORE_OAUTH_CLIENT_SECRET=
PYROSA_CRM_STORE_OAUTH_AUDIENCE=pyrosa-store
PYROSA_CRM_STORE_OAUTH_SCOPE=store.entitlement.decide

PYROSA_CRM_PLATFORM_OAUTH_TOKEN_URL=https://iam.pyrosa.com.do/oauth/token
PYROSA_CRM_PLATFORM_OAUTH_CLIENT_ID=client-pyrosa-crm
PYROSA_CRM_PLATFORM_OAUTH_CLIENT_SECRET=
PYROSA_CRM_PLATFORM_OAUTH_AUDIENCE=pyrosa-platform
PYROSA_CRM_PLATFORM_OAUTH_SCOPE=platform.provisioning.readiness.consume
PYROSA_CRM_ACCESS_TIMEOUT_MS=4000

# Bootstrap transitorio para una cohorte/canary de un solo tenant. Si existe,
# el BFF lo expone como tenant candidato en publicSession y lo usa cuando no
# llega X-Pyrosa-Tenant-Id; Directory, Store y Platform deben autorizarlo en
# cada operacion. No implementa ni sustituye un selector multitenant. Mantener
# vacio cuando un usuario pueda operar mas de un tenant.
PYROSA_CRM_DEFAULT_TENANT_ID=
